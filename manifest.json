{
  "manifest_version": 3,
  "name": "LinkMap",
  "version": "0.1.0",
  "description": "Vertical tabs with tree-style link mapping and premium dark themes",
  "permissions": [
    "tabs",
    "sidePanel",
    "storage",
    "tabGroups",
    "sessions",
    "alarms",
    "unlimitedStorage",
    "history",
    "bookmarks",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Toggle LinkMap",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E"
      },
      "description": "Toggle LinkMap side panel"
    },
    "focus-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "Focus search in LinkMap"
    },
    "close-current-tab": {
      "suggested_key": {
        "default": "Alt+W"
      },
      "description": "Close the current tab"
    },
    "undo-close-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z"
      },
      "description": "Undo close tab"
    }
  }
}
